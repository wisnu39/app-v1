# ============================================================
# Adhitama ERP — Docker Environment Variables
# Copy this file to .env.docker and fill in values
# NEVER commit .env.docker to version control
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=adhitama-postgres
POSTGRES_PORT=5432
POSTGRES_DB=adhitama_dev
POSTGRES_USER=adhitama_user
POSTGRES_PASSWORD=change_this_strong_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=adhitama-redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ─── Application (used by API container — Phase 1+) ──────────
# NODE_ENV=development
# PORT=3000

# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
