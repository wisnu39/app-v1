# ============================================================
# Adhitama ERP — API Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
#
# All variables below are validated at bootstrap (fail-fast).
# App will NOT start if required variables are missing or invalid.
# ============================================================

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────────
# Must match PostgreSQL credentials in .env.docker
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://adhitama_user:change_this_strong_password@localhost:5432/adhitama_dev

# ─── Redis ───────────────────────────────────────────────────
# Must match Redis credentials in .env.docker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ─── JWT Auth (Phase 2) ──────────────────────────────────────
# Security requirements:
#   - Minimum 32 characters each (256-bit entropy)
#   - ACCESS and REFRESH secrets MUST be different values
#   - Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   - Never reuse across environments (dev / staging / production)
#   - Rotate if a breach is suspected

# Access token — short-lived, stateless
# Format: {number}{unit} — e.g. 15m, 1h
JWT_ACCESS_SECRET=change_this_access_secret_minimum_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token — longer-lived, stateful (validated against Session table)
# Format: {number}{unit} — e.g. 7d, 30d
JWT_REFRESH_SECRET=change_this_refresh_secret_must_be_different_from_access
JWT_REFRESH_EXPIRES_IN=7d
