{
  "name": "adhitama",
  "version": "1.0.0",
  "private": true,
  "description": "Adhitama Enterprise Rental ERP — Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run start --workspace=apps/api",
    "api:dev": "npm run start:dev --workspace=apps/api",
    "api:build": "npm run build --workspace=apps/api",
    "api:lint": "npm run lint --workspace=apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "erp",
    "rental",
    "enterprise"
  ],
  "author": "Adhitama Team",
  "license": "UNLICENSED"
}
